# Copy to .env and fill in. .env is gitignored.
#
# Required:
OPENCODE_SERVER_PASSWORD=changeme-openssl-rand-hex-16

# Required when your LM Studio server has auth enabled.
LM_STUDIO_API_KEY=

# Where to reach LM Studio. Defaults to host.docker.internal:1234, which
# works only when LMS is running on the same Mac as Docker. If LMS is on
# another machine on your LAN (or in a VM), set this to its IP/port:
#   LMS_BASE_URL=http://192.168.x.y:1234
# LMS_BASE_URL=http://host.docker.internal:1234

# Other optional overrides — defaults shown.
# LMS_MODEL=lmstudio/google/gemma-4-e4b
# LMS_AUTO_DOWNLOAD=false
# LMS_DISABLE_AUTO_LOAD=false
