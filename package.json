{
  "name": "@hellogravel/opencode-lms",
  "version": "0.1.3",
  "description": "An LM Studio provider plugin for OpenCode — dynamic model discovery, streaming auto-load, and full LM Studio REST API integration",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.15.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.0.0"
  },
  "keywords": [
    "opencode",
    "opencode-plugin",
    "lmstudio",
    "lm-studio",
    "local-llm",
    "openai-compatible",
    "provider"
  ],
  "author": "Hello Gravel <chris@hellogravel.com> (https://hellogravel.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hellogravel/opencode-lms.git"
  },
  "bugs": {
    "url": "https://github.com/hellogravel/opencode-lms/issues"
  },
  "homepage": "https://github.com/hellogravel/opencode-lms#readme",
  "publishConfig": {
    "access": "public"
  }
}
